{
  "name": "aws-secrets-sync",
  "version": "1.0.2",
  "description": "Sync AWS Secrets Manager secrets to/from local .env files",
  "type": "module",
  "bin": {
    "aws-secrets-sync": "./src/bin/cli.js"
  },
  "exports": "./src/bin/cli.js",
  "files": [
    "src/"
  ],
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "download": "node src/bin/cli.js download",
    "upload": "node src/bin/cli.js upload",
    "compare": "node src/bin/cli.js compare",
    "test": "node --test test/*.test.js",
    "lint": "eslint src/ test/"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Cyokin",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/half-6/aws-secrets-sync.git"
  },
  "homepage": "https://github.com/half-6/aws-secrets-sync#readme",
  "bugs": {
    "url": "https://github.com/half-6/aws-secrets-sync/issues"
  },
  "keywords": [
    "aws",
    "secrets-manager",
    "dotenv",
    "env",
    "cli",
    "sync"
  ],
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1030.0",
    "@aws-sdk/credential-providers": "^3.1030.0",
    "commander": "^14.0.3",
    "dotenv": "^16.6.1"
  },
  "overrides": {
    "fast-xml-parser": "^5.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.5.0"
  }
}
