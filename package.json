{
  "name": "aws-secrets-sync",
  "version": "1.0.0",
  "description": "Sync AWS Secrets Manager secrets to/from local .env files",
  "type": "module",
  "bin": {
    "aws-secrets-sync": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "lib/",
    "download-env.js",
    "upload-env.js",
    "compare-env.js",
    "config.js"
  ],
  "scripts": {
    "download": "node download-env.js",
    "upload": "node upload-env.js",
    "compare": "node compare-env.js"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Cyokin",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/half-6/aws-secrets-sync.git"
  },
  "homepage": "https://github.com/half-6/aws-secrets-sync#readme",
  "bugs": {
    "url": "https://github.com/half-6/aws-secrets-sync/issues"
  },
  "keywords": [
    "aws",
    "secrets-manager",
    "dotenv",
    "env",
    "cli",
    "sync"
  ],
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1001.0",
    "commander": "^14.0.3",
    "dotenv": "^16.6.1"
  },
  "overrides": {
    "fast-xml-parser": "^5.4.2"
  }
}
